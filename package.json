{
  "name": "obsidian-claude-mcp",
  "version": "0.1.0",
  "description": "Obsidian community plugin: exposes the vault as a local MCP server.",
  "license": "MIT",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
